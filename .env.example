# =============================================================================
# Copy this to .env and fill in real values. Do NOT commit .env to git.
# =============================================================================

# Shared team password — use a strong random string, at least 16 chars.
# Everyone on the team uses this same password to log in.
# Change it by editing this file and running: docker compose restart
AUTH_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Session signing secret — any long random string. If you change this,
# everyone gets logged out on next visit. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=CHANGE_ME_TO_32_BYTES_HEX
